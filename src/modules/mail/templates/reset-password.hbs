<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <title>Password Reset</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style type="text/css">
        @media screen {
            @font-face {
                font-family: 'Inter';
                font-style: normal;
                font-weight: 400;
                src: local('Inter Regular'), local('Inter-Regular'), url(https://fonts.gstatic.com/s/inter/v12/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuLyfAZJhjp-Ek-_EeA.woff2) format('woff2');
            }
            @font-face {
                font-family: 'Inter';
                font-style: normal;
                font-weight: 700;
                src: local('Inter Bold'), local('Inter-Bold'), url(https://fonts.gstatic.com/s/inter/v12/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuFuYAZJhjp-Ek-_EeA.woff2) format('woff2');
            }
        }
        body, table, td, a {
            -ms-text-size-adjust: 100%; /* 1 */
            -webkit-text-size-adjust: 100%; /* 2 */
        }
        table, td {
            mso-table-rspace: 0pt;
            mso-table-lspace: 0pt;
        }
        img {
            -ms-interpolation-mode: bicubic;
        }
        a[x-apple-data-detectors] {
            font-family: inherit !important;
            font-size: inherit !important;
            font-weight: inherit !important;
            line-height: inherit !important;
            color: inherit !important;
            text-decoration: none !important;
        }
        div[style*="margin: 16px 0;"] {
            margin: 0 !important;
        }
        body {
            width: 100% !important;
            height: 100% !important;
            padding: 0 !important;
            margin: 0 !important;
            background-color: #f4f4f5;
        }
        table {
            border-collapse: collapse !important;
        }
        a {
            color: #4f46e5;
        }
        img {
            height: auto;
            line-height: 100%;
            text-decoration: none;
            border: 0;
            outline: none;
        }
    </style>
</head>
<body style="background-color: #f4f4f5;">
    <!-- start preheader -->
    <div class="preheader" style="display: none; max-width: 0; max-height: 0; overflow: hidden; font-size: 1px; line-height: 1px; color: #fff; opacity: 0;">
        A password reset event has been triggered. The password reset window is limited to 60 minutes.
    </div>
    <!-- end preheader -->

    <!-- start body -->
    <table border="0" cellpadding="0" cellspacing="0" width="100%">
        <!-- start hero -->
        <tr>
            <td align="center" bgcolor="#f4f4f5">
                <table border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width: 600px;">
                    <tr>
                        <td align="left" bgcolor="#ffffff" style="padding: 36px 24px 0; font-family: 'Inter', Helvetica, Arial, sans-serif; border-top: 3px solid #4f46e5; border-radius: 8px 8px 0 0;">
                            <h1 style="margin: 0; font-size: 24px; font-weight: 700; letter-spacing: -1px; line-height: 32px; color: #111827;">Reset Your Password</h1>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
        <!-- end hero -->

        <!-- start copy block -->
        <tr>
            <td align="center" bgcolor="#f4f4f5">
                <table border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width: 600px;">
                    <!-- start copy -->
                    <tr>
                        <td align="left" bgcolor="#ffffff" style="padding: 24px; font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 16px; line-height: 24px; color: #4b5563;">
                            <p style="margin: 0;">We received a request to reset your password. Please use the reset token below or click the button to verify your request. If you didn't request a password reset, you can safely ignore this email.</p>
                        </td>
                    </tr>
                    <!-- end copy -->

                    <!-- start code block -->
                    <tr>
                        <td align="left" bgcolor="#ffffff" style="padding: 12px 24px; font-family: 'Inter', Helvetica, Arial, sans-serif;">
                            <div style="background-color: #f3f4f6; border-radius: 6px; padding: 16px; text-align: center;">
                                <p style="margin: 0; font-family: monospace; font-size: 20px; font-weight: 700; color: #1f2937; letter-spacing: 2px;">{{code}}</p>
                            </div>
                        </td>
                    </tr>
                    <!-- end code block -->

                    <!-- start button -->
                    <tr>
                        <td align="left" bgcolor="#ffffff">
                            <table border="0" cellpadding="0" cellspacing="0" width="100%">
                                <tr>
                                    <td align="center" bgcolor="#ffffff" style="padding: 24px;">
                                        <table border="0" cellpadding="0" cellspacing="0">
                                            <tr>
                                                <td align="center" bgcolor="#4f46e5" style="border-radius: 6px;">
                                                    <a href="{{link}}" target="_blank" style="display: inline-block; padding: 14px 24px; font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 16px; font-weight: 600; color: #ffffff; text-decoration: none; border-radius: 6px;">Reset Password</a>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <!-- end button -->

                    <!-- start copy -->
                    <tr>
                        <td align="left" bgcolor="#ffffff" style="padding: 24px; font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 14px; line-height: 24px; border-bottom: 3px solid #e5e7eb; border-radius: 0 0 8px 8px; color: #6b7280;">
                            <p style="margin: 0;">Thanks,<br> The Security Team</p>
                        </td>
                    </tr>
                    <!-- end copy -->
                </table>
            </td>
        </tr>
        <!-- end copy block -->

        <!-- start footer -->
        <tr>
            <td align="center" bgcolor="#f4f4f5" style="padding: 24px;">
                <table border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width: 600px;">
                    <!-- start permission -->
                    <tr>
                        <td align="center" bgcolor="#f4f4f5" style="padding: 12px 24px; font-family: 'Inter', Helvetica, Arial, sans-serif; font-size: 12px; line-height: 20px; color: #9ca3af;">
                            <p style="margin: 0;">You received this email because we received a request for a password reset for your account. If you didn't request this you can safely delete this email.</p>
                        </td>
                    </tr>
                    <!-- end permission -->
                </table>
            </td>
        </tr>
        <!-- end footer -->
    </table>
    <!-- end body -->
</body>
</html>
